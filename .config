# ==============================================================================
# 1. 核心架构与目标硬件硬编码 (Target & Microarchitecture Specifications)
# ==============================================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7622=y
CONFIG_TARGET_mediatek_mt7622_DEVICE_xiaomi_redmi-router-ax6s=y
CONFIG_LINUX_6_18=y

# ==============================================================================
# 2. 工具链与激进微架构编译优化 (Toolchain & Vectorization Optimizations)
# ==============================================================================
# 极度重要：由于 Ruby 和 Go 极为消耗资源，-O3 和 LTO 将为应用层带来 15% 以上的执行效率提升
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=armv8-a+crc -mtune=cortex-a53 -ffast-math -fno-common -fno-semantic-interposition -flto=auto"
CONFIG_TARGET_LTO=y
CONFIG_USE_STRIP=y
CONFIG_USE_SSTRIP=y
CONFIG_STRIP_KERNEL_EXPORTS=y
# CONFIG_DEBUG is not set

# ==============================================================================
# 3. Linux 内核 6.18 抗压调优 (Kernel Subsystem & Memory Anti-OOM Tuning)
# ==============================================================================
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_DEFAULT_TCP_CONG="bbr"
# 强制开启 MGLRU：应对 OpenClash 规则集和内核页高速缓存的最佳武器
CONFIG_KERNEL_LRU_GEN=y
CONFIG_KERNEL_LRU_GEN_ENABLED=y
# 锁死高性能模式：拒绝因为 CPU 降频导致 Clash 转发抖动
CONFIG_KERNEL_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_KERNEL_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_KERNEL_HZ_100=y
CONFIG_KERNEL_PREEMPT_NONE=y
CONFIG_KERNEL_DEVTMPFS=y
# 激活内核 ZRAM 支持：在内存中开辟一块压缩区域作为 Swap
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y

# ==============================================================================
# 4. 下一代 Firewall4 与 Nftables 核心栈
# ==============================================================================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-tproxy=y

# 保持硬件 PPE 加速：直连流量（如国内流量/测速）依然走纯硬核芯片转发，不占用 CPU
CONFIG_NET_FLOW_OFFLOAD=y
CONFIG_NET_FLOW_OFFLOAD_HARDWARE=y

# ==============================================================================
# 5. OpenClash 核心依赖组件注入 (OpenClash Hard Dependencies)
# ==============================================================================
# 移除原版轻量级 dnsmasq，全面替换为分流专用的 dnsmasq-full
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_nftset=y

# 基础 Web 容器与 LuCI 核心骨架（已做极致精简，仅服务于 OpenClash 面板）
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_uhttpd=y

# 必备系统工具链
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_unzip=y

# 必备重型运行环境
CONFIG_PACKAGE_ruby=y
CONFIG_PACKAGE_ruby-yaml=y

# 内核网络虚拟化与诊断模块（TUN模式与进程识别核心）
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y

# ==============================================================================
# 6. Firewall4 时代的 Iptables-NFT 现代兼容层
# ==============================================================================
# 既不破坏现代 Nftables 架构，又完美兼容 OpenClash 的旧版规则注入
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_ip6tables-mod-nat=y

# ==============================================================================
# 7. Wi-Fi 6 基带纯解与硬件无线流映射 (Wireless WED & 11ax)
# ==============================================================================
CONFIG_PACKAGE_kmod-mtk-eth-soc=y
CONFIG_NET_MEDIATEK_SOC_WED=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_DRIVER_11AX_SUPPORT=y

# 采用 OpenSSL 3.x ARMv8 汇编优化版本，兼顾体积与极速
CONFIG_PACKAGE_wpad-basic-openssl=y
CONFIG_PACKAGE_kmod-crypto-ccmp=y
CONFIG_PACKAGE_kmod-crypto-cmac=y
CONFIG_PACKAGE_kmod-crypto-gcm=y

# ==============================================================================
# 8. 绝对零冗余清单 (Physical Layer Anti-Bloat List)
# ==============================================================================
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb-support is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_kmod-ppp is not set
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set
# CONFIG_PACKAGE_kmod-sound-core is not set
# CONFIG_PACKAGE_etherwake is not set

# ==============================================================================
# 9. 现代基础设施骨架 (Base OS Skeleton)
# ==============================================================================
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_uci=y

# 显式勾选 OpenClash（编译时会自动拉取最新 Release）
CONFIG_PACKAGE_luci-app-openclash=y
