# ==============================================================================
# 1. 核心架构与目标硬件硬编码 (Target & Microarchitecture Specifications)
# ==============================================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7622=y
CONFIG_TARGET_mediatek_mt7622_DEVICE_xiaomi_redmi-router-ax6s=y
CONFIG_LINUX_6_18=y
CONFIG_EXPERIMENTAL=y

# ==============================================================================
# 2. 顶级工具链优化 (修正：规范化标准 STRIP，保护 Go 语言二进制安全)
# ==============================================================================
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=armv8-a+crc -mtune=cortex-a53 -ffast-math -fno-common -fno-semantic-interposition -flto=auto"
CONFIG_TARGET_LTO=y
CONFIG_USE_STRIP=y
# CONFIG_USE_SSTRIP is not set
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_MKLIBS=y
CONFIG_PCRE2_JIT_ENABLED=y
CONFIG_ZSTD_OPTIMIZE_O3=y

# ==============================================================================
# 3. 内存高密度白嫖与内核调度优化 (修正：250Hz 时钟 + BBR 强绑 FQ 队列调度)
# ==============================================================================
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-crypto-zstd=y    # 唤醒 ZSTD 算法，压榨 256MB 内存至双倍可用空间
CONFIG_KERNEL_LRU_GEN=y
CONFIG_KERNEL_LRU_GEN_ENABLED=y

# BBR 圣杯组合：完美触发谷歌流量整形机制，杜绝小包排队抖动
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_DEFAULT_TCP_CONG="bbr"
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-fq=y

CONFIG_KERNEL_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_KERNEL_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
# CONFIG_KERNEL_HZ_100 is not set
CONFIG_KERNEL_HZ_250=y               # 黄金代理时钟节拍，大幅削减 TProxy 转发延迟
CONFIG_KERNEL_PREEMPT_NONE=y

# ==============================================================================
# 4. 全局加密库纯净化：统一收拢至 OpenSSL (彻底拔除 mbedtls)
# ==============================================================================
# CONFIG_LIBCURL_MBEDTLS is not set
CONFIG_LIBCURL_OPENSSL=y
CONFIG_LIBCURL_COOKIES=y
CONFIG_LIBCURL_FILE=y
CONFIG_LIBCURL_FTP=y
CONFIG_LIBCURL_HTTP=y
CONFIG_LIBCURL_HTTP2=y
CONFIG_LIBCURL_HTTP_AUTH=y
CONFIG_LIBCURL_PROXY=y
CONFIG_LIBCURL_UNIX_SOCKETS=y
CONFIG_LIBCURL_ZLIB=y

CONFIG_PACKAGE_libustream-openssl=y
# CONFIG_PACKAGE_libustream-mbedtls is not set
CONFIG_PACKAGE_luci-ssl-openssl=y

# OpenSSL 3.x ARMv8 汇编性能全开
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_libopenssl-conf=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_OPENSSL_WITH_ASM=y
CONFIG_OPENSSL_WITH_CHACHA_POLY1305=y
CONFIG_OPENSSL_WITH_TLS13=y
CONFIG_OPENSSL_ENGINE=y
CONFIG_OPENSSL_WITH_CMS=y
CONFIG_OPENSSL_WITH_DEPRECATED=y
CONFIG_OPENSSL_WITH_ERROR_MESSAGES=y
CONFIG_OPENSSL_WITH_IDEA=y
CONFIG_OPENSSL_WITH_MDC2=y
CONFIG_OPENSSL_WITH_PSK=y
CONFIG_OPENSSL_WITH_SEED=y
CONFIG_OPENSSL_WITH_SRP=y
CONFIG_OPENSSL_WITH_WHIRLPOOL=y

# ==============================================================================
# 5. DNS 核心数据路径与审计去噪 (Dnsmasq-Full 极致纯净体)
# ==============================================================================
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_nftset=y
CONFIG_PACKAGE_dnsmasq_full_auth=y
CONFIG_PACKAGE_dnsmasq_full_conntrack=y
CONFIG_PACKAGE_dnsmasq_full_noid=y

# 深度审计剔除模块：杜绝 Dnsmasq 本地进行复杂的签名验证和无用刷机协议
# CONFIG_PACKAGE_dnsmasq_full_dnssec is not set
# CONFIG_PACKAGE_dnsmasq_full_tftp is not set

# ==============================================================================
# 6. 下一代 Firewall4 / Nftables 现代内核网络栈
# ==============================================================================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-netdev=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y

# 保持硬件 PPE 加速：直连国内流量纯硬件芯片级转发，绝不无谓消耗 CPU
CONFIG_NET_FLOW_OFFLOAD=y
CONFIG_NET_FLOW_OFFLOAD_HARDWARE=y
CONFIG_PACKAGE_miniupnpd-nftables=y

# ==============================================================================
# 7. OpenClash 及其全套硬核依赖链注入 (完全满足指定依赖)
# ==============================================================================
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_unzip=y

# 核心重型环境：掌控 OpenClash 控制面配置解析
CONFIG_PACKAGE_ruby=y
CONFIG_PACKAGE_ruby-yaml=y

# 内核虚拟化路径与进程识别诊断
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y

# Firewall4 时代的 Iptables-NFT 现代兼容翻译层（满足 TProxy 规则注入）
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_ip6tables-mod-nat=y

# ==============================================================================
# 8. 无线 WAN 与 IPv6 动态寻址栈 (WWAN & WWAN6 Core Stack)
# ==============================================================================
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_odhcpd_ipv6only_ext_cer_id=y
CONFIG_IPV6=y
CONFIG_PACKAGE_luci-proto-ipv6=y

# ==============================================================================
# 9. 满足指定应用组件 (已精准剥离 ddns 与 ttyd，并剔除硬件不匹配工具)
# ==============================================================================
# AdGuardHome 核心与面板
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y

# SmartDNS 引擎
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y

# 网络唤醒 WOL
CONFIG_PACKAGE_etherwake=y
CONFIG_PACKAGE_luci-app-wol=y

# 基础测试与网络诊断工具
CONFIG_PACKAGE_htop=y
CONFIG_HTOP_LMSENSORS=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_tar=y

# 目标精准屏蔽组件
# CONFIG_PACKAGE_ddns-scripts is not set
# CONFIG_PACKAGE_ddns-scripts-services is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
# CONFIG_PACKAGE_ttyd is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set

# 深度审计物理不匹配清退列表 (无 USB，斩断死重依赖)
# CONFIG_PACKAGE_lsblk is not set
# CONFIG_PACKAGE_openssh-sftp-server is not set
# CONFIG_PACKAGE_bzip2 is not set
# CONFIG_PACKAGE_xz is not set
# CONFIG_PACKAGE_xz-utils is not set

# ==============================================================================
# 10. Wi-Fi 芯片驱动与射频解禁补丁 (唤醒 SafeXcel 硬件解密，解锁 5G 发射功率)
# ==============================================================================
CONFIG_PACKAGE_kmod-mtk-eth-soc=y
CONFIG_NET_MEDIATEK_SOC_WED=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_DRIVER_11AX_SUPPORT=y

# 激活 MT7622 芯片内置的 SafeXcel (EIP-97) 硬件加密引擎，全局释放 CPU 算力
CONFIG_PACKAGE_kmod-crypto-hw-safexcel=y

# 降级 wpad 瘦身，剔除庞大的企业级 RADIUS 认证栈
# CONFIG_PACKAGE_wpad-openssl is not set
CONFIG_PACKAGE_wpad-basic-openssl=y
CONFIG_PACKAGE_kmod-crypto-ccmp=y
CONFIG_PACKAGE_kmod-crypto-cmac=y
CONFIG_PACKAGE_kmod-crypto-gcm=y

# 射频解锁工具：强制注入无线区域数据库，解除 20dBm 锁死，完整开辟 5G 高频信道
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_kmod-cfg80211=y

# ==============================================================================
# 11. LuCI 核心骨架、底层中间件及汉化 (已移除 ddns, ttyd 语言包及二维码冗余)
# ==============================================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_cgi-io=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_rpcd-mod-file=y
CONFIG_PACKAGE_rpcd-mod-iwinfo=y
CONFIG_PACKAGE_rpcd-mod-luci=y
CONFIG_PACKAGE_rpcd-mod-rrdns=y
CONFIG_PACKAGE_rpcd-mod-ucode=y
CONFIG_PACKAGE_ucode-mod-html=y
CONFIG_PACKAGE_ucode-mod-log=y
CONFIG_PACKAGE_ucode-mod-math=y
CONFIG_PACKAGE_resolveip=y

CONFIG_PACKAGE_libacl=y
CONFIG_PACKAGE_libatomic=y
CONFIG_PACKAGE_libattr=y
CONFIG_PACKAGE_libbpf=y
CONFIG_PACKAGE_libelf=y
CONFIG_PACKAGE_libgmp=y
CONFIG_PACKAGE_libiperf3=y
CONFIG_PACKAGE_libiwinfo=y
CONFIG_PACKAGE_libiwinfo-data=y
CONFIG_PACKAGE_liblucihttp=y
CONFIG_PACKAGE_liblucihttp-ucode=y
CONFIG_PACKAGE_liblzma=y
CONFIG_PACKAGE_libmount=y
CONFIG_PACKAGE_libncurses=y
CONFIG_PACKAGE_libnetfilter-conntrack=y
CONFIG_PACKAGE_libnettle=y
CONFIG_PACKAGE_libnfnetlink=y
CONFIG_PACKAGE_libnghttp2=y
CONFIG_PACKAGE_libpthread=y
CONFIG_PACKAGE_libreadline=y
CONFIG_PACKAGE_librt=y
CONFIG_PACKAGE_terminfo=y

CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y

# 语言包与视觉组件深度去噪
# CONFIG_PACKAGE_luci-i18n-ddns-zh-cn is not set
# CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn is not set
# CONFIG_PACKAGE_luci-lib-uqr is not set

# ==============================================================================
# 12. 彻底剥离历史拨号包袱与编译签名认证冗余 (Scrubbing Bloatware)
# ==============================================================================
# CONFIG_PACKAGE_luci-proto-ppp is not set
# CONFIG_PACKAGE_openwrt-keyring is not set
# CONFIG_PACKAGE_usign is not set
# CONFIG_SIGNATURE_CHECK is not set
# CONFIG_SIGNED_PACKAGES is not set
