# ==============================================================================
# 1. 核心架构与目标硬件硬编码 (Target & Microarchitecture Specifications)
# ==============================================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7622=y
CONFIG_TARGET_mediatek_mt7622_DEVICE_xiaomi_redmi-router-ax6s=y
CONFIG_LINUX_6_18=y

# ==============================================================================
# 2. 顶配编译链与极端矢量化优化 (Ultimate Toolchain & LTO Optimizations)
# ==============================================================================
# 深度压榨 Cortex-A53 双核性能，强制开启最高级别矢量化与全链路时序优化
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=armv8-a+crc -mtune=cortex-a53 -ffast-math -fno-common -fno-semantic-interposition -flto=auto"
CONFIG_TARGET_LTO=y
CONFIG_USE_STRIP=y
CONFIG_USE_SSTRIP=y
CONFIG_STRIP_KERNEL_EXPORTS=y
# CONFIG_DEBUG is not set
# CONFIG_KERNEL_DEBUG_FS is not set
# CONFIG_KERNEL_DEBUG_INFO is not set
# CONFIG_KERNEL_CORESIGHT is not set

# ==============================================================================
# 3. Linux 内核 6.18 纯净吞吐级调优 (Kernel Subsystem & Low-Latency Tuning)
# ==============================================================================
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_DEFAULT_TCP_CONG="bbr"
CONFIG_KERNEL_LRU_GEN=y
CONFIG_KERNEL_LRU_GEN_ENABLED=y
CONFIG_KERNEL_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_KERNEL_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y

# 吞吐量优先：将时钟滴答强行降至 100Hz，最大化减少 CPU 上下文切换损耗
CONFIG_KERNEL_HZ_100=y
CONFIG_KERNEL_PREEMPT_NONE=y

# 彻底剥离不必要的内核子系统，降低内核空间内存踩踏与无谓的调度开销
# CONFIG_KERNEL_SCHED_AUTOGROUP is not set
# CONFIG_KERNEL_CGROUPS is not set
# CONFIG_KERNEL_NAMESPACES is not set
# CONFIG_KERNEL_IKCONFIG is not set
# CONFIG_KERNEL_SECCOMP is not set
# CONFIG_KERNEL_AIO is not set
# CONFIG_KERNEL_IO_URING is not set
CONFIG_KERNEL_DEVTMPFS=y

# ==============================================================================
# 4. 纯净 Nftables 硬件级数据路径 (Modern Hardware Packet Forwarding Engine)
# ==============================================================================
# 彻底埋葬 Iptables 时代历史垃圾
# CONFIG_PACKAGE_firewall is not set
# CONFIG_PACKAGE_iptables is not set
# CONFIG_PACKAGE_kmod-iptables is not set
# CONFIG_PACKAGE_kmod-ipt-core is not set
# CONFIG_PACKAGE_kmod-ip6tables is not set
# CONFIG_PACKAGE_kmod-ebtables is not set

# 激进激活全套主线 Nftables / Firewall4 架构
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y

# 纠正历史倒退：拨乱反正，全面清退软件 SFE，交由硬件 PPE 独占接管
# CONFIG_PACKAGE_kmod-shortcut-fe is not set
# CONFIG_PACKAGE_kmod-shortcut-fe-cm is not set
CONFIG_NET_FLOW_OFFLOAD=y
CONFIG_NET_FLOW_OFFLOAD_HARDWARE=y

# ==============================================================================
# 5. Wi-Fi 6 基带纯解与硬件无线流映射 (Wireless WED & 11ax Native Datapath)
# ==============================================================================
# 激活 MTK 独家芯片级硬件无线分发引擎 (WED)
CONFIG_PACKAGE_kmod-mtk-eth-soc=y
CONFIG_NET_MEDIATEK_SOC_WED=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_DRIVER_11AX_SUPPORT=y

# 移除重型企业级 WPA-Enterprise 负担，只保留轻量现代安全栈 (WPA2/WPA3 Personal)
# 采用 OpenSSL 3.x 针对 ARMv8 汇编优化的 Basic 版本，兼顾体积与极端加解密速度
CONFIG_PACKAGE_wpad-basic-openssl=y
# CONFIG_PACKAGE_wpad-openssl is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_kmod-crypto-tkip is not set
# CONFIG_PACKAGE_kmod-crypto-wep is not set
CONFIG_PACKAGE_kmod-crypto-ccmp=y
CONFIG_PACKAGE_kmod-crypto-cmac=y
CONFIG_PACKAGE_kmod-crypto-gcm=y

# ==============================================================================
# 6. 物理断舍离与绝对零冗余清单 (Physical Layer Anti-Bloat List)
# ==============================================================================
# AX6S 物理无 USB，斩断一切物理层不匹配的驱动与内核栈
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb-support is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set

# 拒绝 PPPoE 历史包袱（坚守纯粹的光猫桥接 DHCP / 静态IP 现代拓扑）
# CONFIG_PACKAGE_kmod-ppp is not set
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set

# 彻底移除一切与核心路由转发无关的残留组件
# CONFIG_PACKAGE_kmod-sound-core is not set
# CONFIG_PACKAGE_etherwake is not set

# ==============================================================================
# 7. 现代最小化基础设施骨架 (Minimalist Base OS Skeleton)
# ==============================================================================
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_uci=y
